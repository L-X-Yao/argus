{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for PL-Link GCS",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/python-backend",
          "sidecar": true,
          "args": [
            "--port",
            {
              "validator": "\\d+"
            }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/python-backend",
          "sidecar": true,
          "args": [
            "--port",
            {
              "validator": "\\d+"
            }
          ]
        }
      ]
    }
  ]
}
