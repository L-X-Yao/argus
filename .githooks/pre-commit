#!/bin/bash
# Pre-commit gate: lint + type-check (fast, <5s).
# Full test suite runs on push — see .githooks/pre-push.
# Install: git config core.hooksPath .githooks
set -e

echo "[pre-commit] ruff..."
ruff check backend/ scripts/ tests/ --quiet

echo "[pre-commit] svelte-check..."
npx svelte-check --tsconfig ./tsconfig.json 2>&1 | tail -1 | grep -q '0 ERRORS' || {
  echo "svelte-check failed"; exit 1;
}

echo "[pre-commit] OK"
