#!/bin/bash
# Pre-push gate: full test suite.
# Runs before pushing to remote — catches anything pre-commit skipped.
set -e

echo "[pre-push] vitest..."
npx vitest run --bail 1 --reporter=dot 2>&1 | tail -1

echo "[pre-push] pytest..."
python -m pytest tests/test_unit_*.py tests/test_contract_*.py -q --tb=line -x 2>&1 | tail -1

echo "[pre-push] OK"
